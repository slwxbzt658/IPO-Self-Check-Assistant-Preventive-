# === 永远忽略的文件 ===
.env
__pycache__/
*.pyc
*.pyo
.DS_Store
demos/demo_output/
data/raw/

# === 放行所有源代码和文档 ===
# 根目录文件
!README.md
!.gitignore
!.env.example
!requirements.txt

# src/ 源代码全部放行
!src/
!src/**

# demos/ 脚本放行（但 demo_output 已在忽略列表）
!demos/
!demos/demo_input/
!demos/demo_input/**
!demos/*.py

# docs/ 白皮书全部放行
!docs/
!docs/**
